{
  "version": 2,
  "installCommand": "cd frontend/crimson-bazaar-jsx && npm install --no-audit --no-fund",
  "buildCommand": "cd frontend/crimson-bazaar-jsx && npm run build",
  "outputDirectory": "frontend/crimson-bazaar-jsx/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}